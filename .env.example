# ─── Database ───────────────────────────────────────────────
# Neon PostgreSQL — get free DB at neon.tech
# Use the NON-pooled (direct) connection string
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# ─── Auth ────────────────────────────────────────────────────
# For local development use NEXTAUTH_SECRET
# For Vercel deployment use AUTH_SECRET (same value, different name)
NEXTAUTH_SECRET="any-random-string"
AUTH_SECRET="any-random-string"

# Your app URL — http://localhost:3000 locally, https://xxx.vercel.app on Vercel
NEXTAUTH_URL="http://localhost:3000"

# ─── Phase 2: Data APIs ──────────────────────────────────────
ALPHA_VANTAGE_API_KEY=
CRICAPI_KEY=
NEWS_API_KEY=

# ─── Phase 3: AI + Cron ──────────────────────────────────────
ANTHROPIC_API_KEY=
CRON_SECRET=

# ─── Phase 5: Notifications ──────────────────────────────────
RESEND_API_KEY=
TELEGRAM_BOT_TOKEN=
